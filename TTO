                const now = Math.floor(Date.now() / 1000);
                let remainingSeconds = parseInt(savedEndTime) - now;

                if (remainingSeconds > 0) {
                    isGlobalVipUnlocked = true;
                    displayAllTables();
                    document.getElementById('keyCode').disabled = true;
                    document.querySelector('.activation-btn').disabled = true;
                    startSubscriptionCountdown(savedPackageName, remainingSeconds);
                } else {
                    localStorage.removeItem('vip_end_time');
                    localStorage.removeItem('vip_package_name');
                }
            }
        }

        function checkActivationCode() {
            const inputCode = document.getElementById('keyCode').value.trim().toUpperCase();
            const statusMsg = document.getElementById('statusMsg');

            if (vipCodesDatabase.hasOwnProperty(inputCode)) {
                const codeData = vipCodesDatabase[inputCode];
                statusMsg.style.color = "var(--green-success)";
                statusMsg.innerText = `✅ تم التفعيل بنجاح! باقة [ ${codeData.name} ] نشطة الآن.`;
                
                isGlobalVipUnlocked = true;
                displayAllTables();
                
                document.getElementById('keyCode').disabled = true;
                document.querySelector('.activation-btn').disabled = true;

                const durationSeconds = codeData.hours * 3600;
                const endTimeTimestamp = Math.floor(Date.now() / 1000) + durationSeconds;
                
                localStorage.setItem('vip_end_time', endTimeTimestamp);
                localStorage.setItem('vip_package_name', codeData.name);

                startSubscriptionCountdown(codeData.name, durationSeconds);
            } else {
                statusMsg.style.color = "var(--live-red)";
                statusMsg.innerText = "❌ كود التفعيل خاطئ، مستخدم سابقاً أو منتهي الصلاحية!";
                openVipModal();
            }
        }

        function startSubscriptionCountdown(packageName, totalSeconds) {
            const infoBox = document.getElementById('subInfoBox');
            const subTitle = document.getElementById('subTitle');
            const subCountdown = document.getElementById('subCountdown');
            
            subTitle.innerText = `👑 حالة الاشتراك: ${packageName} نشط`;
            infoBox.style.display = 'block';

            if (subscriptionInterval) clearInterval(subscriptionInterval);

            subscriptionInterval = setInterval(function() {
                const savedEndTime = localStorage.getItem('vip_end_time');
                if (!savedEndTime) {
                    clearInterval(subscriptionInterval);
                    return;
                }
                
                const now = Math.floor(Date.now() / 1000);
                let currentRemaining = parseInt(savedEndTime) - now;

                if (currentRemaining <= 0) {
                    clearInterval(subscriptionInterval);
                    subCountdown.innerText = "❌ انتهت صلاحية الاشتراك الحالي!";
                    subCountdown.style.color = "var(--live-red)";
                    localStorage.removeItem('vip_end_time');
                    localStorage.removeItem('vip_package_name');
                    isGlobalVipUnlocked = false;
                    displayAllTables();
                    return;
                }

                let d = Math.floor(currentRemaining / (3600 * 24));
                let h = Math.floor((currentRemaining % (3600 * 24)) / 3600);
                let m = Math.floor((currentRemaining % 3600) / 60);
                let s = currentRemaining % 60;

                subCountdown.innerText = `${d} يوم و ${h} ساعة و ${m} دقيقة و ${s} ثانية`;
            }, 1000);
        }

        function startTimer() {
            let hours = 1, minutes = 42, seconds = 25;
            setInterval(function() {
                if (seconds > 0) seconds--;
                else {
                    seconds = 59;
                    if (minutes > 0) minutes--;
                    else { minutes = 59; if (hours > 0) hours--; }
                }
                document.getElementById('timer').innerText = 
                    (hours < 10 ? "0" + hours : hours) + ":" + 
                    (minutes < 10 ? "0" + minutes : minutes) + ":" + 
                    (seconds < 10 ? "0" + seconds : seconds);
            }, 1000);
        }

        window.onload = function() {
            checkSavedSubscription(); 
            displayAllTables();
            startTimer();
            window.onclick = function(event) {
                let modal = document.getElementById('vipModal');
                if (event.target == modal) { modal.style.display = "none"; }
            }
        }
    </script>
</body>
</html>
